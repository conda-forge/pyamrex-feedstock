diff --git a/setup.py b/setup.py
index 719df33a..45cf7e37 100644
--- a/setup.py
+++ b/setup.py
@@ -95,7 +95,7 @@ def build_extension(self, ext):
             "-DAMReX_GPU_BACKEND=" + AMReX_GPU_BACKEND,
